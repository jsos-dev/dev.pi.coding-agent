const process = require('process');
const { Worker } = require('worker_threads');

// ============================================================
// Simple Module System
// ============================================================
const moduleCache = {};
const moduleExports = {};

function requireModule(name) {
  if (moduleCache[name]) return moduleCache[name];
  if (!moduleFactories[name]) throw new Error(`Module '${name}' not found`);
  const mod = { exports: {} };
  moduleFactories[name](mod, mod.exports);
  moduleCache[name] = mod.exports;
  return mod.exports;
}

const moduleFactories = {};


  // Module: filesystem.js
  moduleFactories['filesystem'] = function(module, exports) {
'use strict';

const os = require('os');
const path = require('path');
const fs = require('fs');

const isWindows = process.platform === 'win32';
const MAIN_SEPARATOR = path.sep;

function pathAbsoluteForm(p) {
  if (path.isAbsolute(p)) {
    return path.resolve(p);
  }
  return path.resolve(process.cwd(), p);
}

function absolutePath(p) {
  let abs = pathAbsoluteForm(p);
  if (isWindows) {
    abs = abs.replace(/^\\\\\?\\/, '');
  }
  return abs;
}

function isExistingDirectory(p) {
  try {
    const stat = fs.statSync(p, { throwIfNoEntry: false });
    return stat !== undefined && stat.isDirectory();
  } catch {
    return false;
  }
}

function isEmpty(entry) {
  try {
    if (entry.isDirectory()) {
      const files = fs.readdirSync(entry.path);
      return files.length === 0;
    }
    return entry.size === 0;
  } catch {
    return false;
  }
}

function isBlockDevice(stat) {
  if (isWindows) return false;
  return stat.isBlockDevice ? stat.isBlockDevice() : false;
}

function isCharDevice(stat) {
  if (isWindows) return false;
  return stat.isCharacterDevice ? stat.isCharacterDevice() : false;
}

function isSocket(stat) {
  if (isWindows) return false;
  return stat.isSocket ? stat.isSocket() : false;
}

function isPipe(stat) {
  if (isWindows) return false;
  return stat.isFIFO ? stat.isFIFO() : false;
}

function osstrToBytes(input) {
  if (typeof input === 'string') {
    return Buffer.from(input);
  }
  return Buffer.from(input);
}

function stripCurrentDir(p) {
  if (p.startsWith('./')) {
    return p.slice(2);
  }
  return p;
}

function defaultPathSeparator() {
  if (isWindows) {
    const msys = process.env.MSYSTEM;
    if (msys && (msys.startsWith('MINGW') || msys.startsWith('MSYS'))) {
      return '/';
    }
  }
  return null;
}

function getExtension(filename) {
  const dotIndex = filename.lastIndexOf('.');
  if (dotIndex > 0) {
    return filename.slice(dotIndex + 1);
  }
  return '';
}

module.exports = {
  isWindows,
  MAIN_SEPARATOR,
  pathAbsoluteForm,
  absolutePath,
  isExistingDirectory,
  isEmpty,
  isBlockDevice,
  isCharDevice,
  isSocket,
  isPipe,
  osstrToBytes,
  stripCurrentDir,
  defaultPathSeparator,
  getExtension,
};
  };

